# Development Dockerfile for the backend Node.js + Express app.
# Source code is mounted as a volume by docker-compose — only deps are baked in.

FROM node:20-alpine
WORKDIR /app

RUN npm install -g pnpm@latest

# Les chemins sont relatifs au context (racine du repo)
COPY backend/package.json backend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

EXPOSE 3000
# --watch : hot-reload natif Node 18+, pas besoin de nodemon
CMD ["node", "--watch", "server.js"]
