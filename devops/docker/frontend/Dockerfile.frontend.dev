# Development Dockerfile for the frontend React + Vite app.
# Starts the Vite dev server with host 0.0.0.0 so it is reachable from Docker.

FROM node:20-alpine
WORKDIR /app

RUN npm install -g pnpm@latest

# Les chemins sont relatifs au context (racine du repo)
COPY frontend/package.json frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Le code source est monté en volume par docker-compose (pas besoin de COPY . .)
EXPOSE 5173
CMD ["pnpm", "dev"]

